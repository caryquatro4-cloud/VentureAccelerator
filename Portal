  color:rgba(0,212,255,0.78); margin-top:2px;
}
.nav-links { display:flex; align-items:center; gap:4px; flex-wrap:wrap; }
.nav-a {
  font-family:'Rajdhani',sans-serif; font-weight:600; font-size:0.76rem;
  letter-spacing:0.12em; text-transform:uppercase; text-decoration:none;
  color:rgba(255,255,255,0.58); padding:7px 13px; border-radius:3px;
  border:1px solid transparent; transition:all 0.22s;
}
.nav-a:hover, .nav-a.active {
  color:var(--yellow); border-color:rgba(255,215,0,0.32); background:rgba(255,215,0,0.07);
}
.nav-sep { color:rgba(255,255,255,0.18); font-size:0.8rem; padding:0 2px; }
.nav-cta {
  font-family:'Rajdhani',sans-serif; font-weight:700; font-size:0.76rem;
  letter-spacing:0.15em; text-transform:uppercase; text-decoration:none;
  color:var(--blue-deep); background:var(--yellow);
  padding:9px 20px; border-radius:3px;
  border:2px solid var(--yellow); transition:all 0.22s; margin-left:6px;
}
.nav-cta:hover { background:transparent; color:var(--yellow); }
/* ── PAGE FOOTER ── */
.page-footer {
  border-top:1px solid rgba(255,215,0,0.14); margin-top:60px;
  background:rgba(6,0,90,0.75); backdrop-filter:blur(12px);
  padding:28px 40px; position:relative; z-index:1;
}
.page-footer-inner {
  max-width:1280px; margin:0 auto;
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px;
}
.footer-left  { font-size:0.68rem; color:rgba(255,255,255,0.25); letter-spacing:0.08em; }
.footer-right { font-family:'DM Mono',monospace; font-size:0.62rem; color:rgba(255,215,0,0.3); letter-spacing:0.18em; }
.footer-nav   { display:flex; gap:18px; }
.footer-link  {
  font-family:'Rajdhani',sans-serif; font-weight:600; font-size:0.68rem;
  letter-spacing:0.12em; text-transform:uppercase; text-decoration:none;
  color:rgba(255,255,255,0.32); transition:color 0.2s;
}
.footer-link:hover { color:var(--yellow); }
@media(max-width:700px){
  .nav-links { display:none; }
