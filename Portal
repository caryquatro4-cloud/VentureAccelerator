              + '<div class="cust-block"><div class="cust-label">Existing Customers</div><div class="cust-tags">'+tagsHtml(c.existing,'tag-existing')+'</div></div>'
              + '<div class="cust-block"><div class="cust-label">Target Customers</div><div class="cust-tags">'+tagsHtml(c.targets,'tag-target')+'</div></div>'
