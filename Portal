<style>
  

  * { margin: 0; padding: 0; box-sizing: border-box; }

  

  

  

  .container { max-width: 1280px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 1; }

  /* ── HEADER ── */
  header {
    padding: 28px 0 24px;
    border-bottom: 1px solid rgba(255,215,0,0.2);
    position: sticky; top: 0;
    background: rgba(10,0,168,0.9);
    backdrop-filter: blur(16px);
    z-index: 100;
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .logo-group { display: flex; align-items: center; gap: 14px; }
  
  .logo-text { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.4rem; letter-spacing: 0.08em; text-transform: uppercase; }
  .logo-text span { color: var(--yellow); }
  .header-badge { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); border: 1px solid rgba(0,212,255,0.3); padding: 4px 10px; border-radius: 2px; }
  nav { display: flex; gap: 8px; flex-wrap: wrap; }
  .nav-btn {
    font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.8rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    background: transparent; border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7); padding: 8px 16px; border-radius: 3px; cursor: pointer; transition: all 0.2s;
  }
  .nav-btn:hover, .nav-btn.active { background: rgba(255,215,0,0.1); border-color: var(--yellow); color: var(--yellow); }

  /* ── HERO ── */
  .hero { padding: 72px 0 56px; text-align: center; }
  .hero-eyebrow {
    font-size: 0.7rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--teal);
    margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 12px;
  }
  .hero-eyebrow::before, .hero-eyebrow::after { content: ''; width: 48px; height: 1px; background: var(--teal); opacity: 0.5; }
  .hero h1 { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: clamp(2.4rem, 5vw, 4rem); line-height: 1.05; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 20px; }
  .hero h1 em { font-style: normal; color: var(--yellow); display: block; }
  .hero-sub { font-size: 1rem; color: rgba(255,255,255,0.65); max-width: 580px; margin: 0 auto 40px; line-height: 1.65; font-weight: 300; }

  /* ── STATS ── */
  .stats-bar { display: flex; justify-content: center; border: 1px solid rgba(255,215,0,0.2); border-radius: 6px; overflow: hidden; max-width: 860px; margin: 0 auto 64px; flex-wrap: wrap; }
  .stat-item { flex: 1; min-width: 130px; padding: 20px 24px; text-align: center; border-right: 1px solid rgba(255,215,0,0.15); background: rgba(255,255,255,0.03); }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.9rem; color: var(--yellow); line-height: 1; margin-bottom: 4px; }
  .stat-label { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.45); }

  /* ── FILTERS ── */
  .filters { display: flex; align-items: center; gap: 10px; margin-bottom: 36px; flex-wrap: wrap; }
  .filter-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
  .filter-btn {
    font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.75rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: transparent; border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.6); padding: 7px 16px; border-radius: 3px; cursor: pointer; transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active { background: rgba(255,215,0,0.12); border-color: rgba(255,215,0,0.6); color: var(--yellow); }

  /* ── SECTION HEADER ── */
  .section-header { display: flex; align-items: baseline; gap: 16px; margin-bottom: 28px; }
  .section-title { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.5rem; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }
  .section-title span { color: var(--yellow); }
  .section-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(255,215,0,0.3), transparent); }

  /* ── CARDS ── */
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px; margin-bottom: 64px; }

  .card {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--card-border);
    border-radius: 6px; overflow: hidden;
    transition: all 0.3s ease; cursor: pointer;
    position: relative; display: flex; flex-direction: column;
    animation: fadeUp 0.4s ease both;
  }
  .card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--yellow), transparent);
    opacity: 0; transition: opacity 0.3s; z-index: 2;
  }
  .card:hover { border-color: rgba(255,215,0,0.6); background: rgba(255,255,255,0.08); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 30px rgba(255,215,0,0.08); }
  .card:hover::before { opacity: 1; }

  /* Card image */
  .card-image { width: 100%; height: 175px; overflow: hidden; background: rgba(0,0,0,0.3); position: relative; flex-shrink: 0; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .card:hover .card-image img { transform: scale(1.05); }
  .card-img-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
    background: linear-gradient(135deg, rgba(0,0,80,0.7), rgba(0,40,120,0.5));
  }
  .card-img-placeholder .ph-icon { font-size: 2.5rem; opacity: 0.45; }
  .card-img-placeholder .ph-label { font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.25); }
  .card-image-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 64px; background: linear-gradient(transparent, rgba(10,0,168,0.9)); pointer-events: none; }
  .card-invest-badge {
    position: absolute; top: 10px; right: 10px; z-index: 2;
    font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 0.78rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: rgba(0,0,0,0.65); border: 1px solid rgba(255,215,0,0.55);
    color: var(--yellow); padding: 4px 10px; border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .card-header { padding: 14px 18px 12px; border-bottom: 1px solid rgba(255,255,255,0.07); display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
  .card-company { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.15rem; letter-spacing: 0.06em; text-transform: uppercase; line-height: 1.1; }
  .card-sector-tag { font-size: 0.57rem; letter-spacing: 0.17em; text-transform: uppercase; color: var(--teal); margin-top: 3px; }
  .card-stage { font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.12); padding: 3px 8px; border-radius: 2px; white-space: nowrap; }

  .card-body { padding: 13px 18px; flex: 1; }
  .card-desc { font-size: 0.82rem; color: rgba(255,255,255,0.62); line-height: 1.58; margin-bottom: 13px; font-weight: 300; }
  .cust-block { margin-bottom: 10px; }
  .cust-label { font-size: 0.57rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.33); margin-bottom: 5px; }
  .cust-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .tag { font-size: 0.62rem; padding: 2px 8px; border-radius: 2px; }
  .tag-existing { background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.22); color: var(--teal); }
  .tag-target   { background: rgba(255,215,0,0.07); border: 1px solid rgba(255,215,0,0.22); color: rgba(255,215,0,0.8); }

  .card-footer { padding: 11px 18px; border-top: 1px solid rgba(255,255,255,0.07); display: flex; gap: 8px; }
  .btn-room {
    flex: 1; font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.7rem;
    letter-spacing: 0.14em; text-transform: uppercase;
    background: rgba(255,215,0,0.12); border: 1px solid rgba(255,215,0,0.4);
    color: var(--yellow); padding: 9px 12px; border-radius: 3px; cursor: pointer; transition: all 0.2s; text-align: center;
  }
  .btn-room:hover { background: rgba(255,215,0,0.22); border-color: var(--yellow); }
  .btn-more {
    font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.7rem;
    letter-spacing: 0.14em; text-transform: uppercase;
    background: transparent; border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.45); padding: 9px 12px; border-radius: 3px; cursor: pointer; transition: all 0.2s;
  }
  .btn-more:hover { border-color: rgba(255,255,255,0.35); color: var(--white); }

  /* ── MODAL ── */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(5,0,80,0.88); backdrop-filter: blur(8px);
    z-index: 200; align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: #0d00d0; border: 1px solid rgba(255,215,0,0.35); border-radius: 8px;
    max-width: 660px; width: 100%; max-height: 92vh; overflow-y: auto; position: relative;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
  }
  .modal::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--yellow), var(--teal)); z-index: 2; }

  .modal-hero { width: 100%; height: 200px; overflow: hidden; position: relative; background: #080070; flex-shrink: 0; }
  .modal-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .modal-hero-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 4.5rem; opacity: 0.35; background: linear-gradient(135deg, #060060, #0030a0); }
  .modal-hero-fade { position: absolute; bottom: 0; left: 0; right: 0; height: 80px; background: linear-gradient(transparent, #0d00d0); }

  .modal-header { padding: 18px 28px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .modal-name { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.9rem; letter-spacing: 0.05em; text-transform: uppercase; line-height: 1; margin-bottom: 5px; }
  .modal-sector { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--teal); }
  .modal-x { background: transparent; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.55); width: 34px; height: 34px; border-radius: 3px; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.2s; }
  .modal-x:hover { border-color: var(--yellow); color: var(--yellow); }

  .modal-body { padding: 20px 28px 28px; }
  .modal-stats { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
  .m-stat { flex: 1; min-width: 90px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 12px 14px; text-align: center; }
  .m-stat-val { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 1.35rem; color: var(--yellow); }
  .m-stat-lbl { font-size: 0.57rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-top: 2px; }

  .modal-desc { font-size: 0.9rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 20px; font-weight: 300; }
  .modal-cust-lbl { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.33); margin-bottom: 8px; }
  .modal-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px; }
  .m-tag { font-size: 0.68rem; padding: 4px 11px; border-radius: 2px; }

  .dr-box { background: rgba(0,0,0,0.22); border: 1px solid rgba(255,215,0,0.2); border-radius: 4px; padding: 18px; }
  .dr-title { font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--yellow); margin-bottom: 14px; }
  .form-row { display: flex; gap: 10px; margin-bottom: 10px; }
  .f-input { flex: 1; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 3px; color: var(--white); font-family: 'Exo 2', sans-serif; font-size: 0.82rem; padding: 10px 13px; outline: none; transition: border-color 0.2s; }
  .f-input::placeholder { color: rgba(255,255,255,0.3); }
  .f-input:focus { border-color: rgba(255,215,0,0.5); }
  .f-submit { width: 100%; font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 0.84rem; letter-spacing: 0.2em; text-transform: uppercase; background: rgba(255,215,0,0.14); border: 1px solid rgba(255,215,0,0.5); color: var(--yellow); padding: 12px; border-radius: 3px; cursor: pointer; transition: all 0.2s; margin-top: 4px; }
  .f-submit:hover { background: rgba(255,215,0,0.24); border-color: var(--yellow); }
  .f-submit:disabled { opacity: 0.55; cursor: default; }
  .divider { display: flex; align-items: center; gap: 12px; margin: 14px 0; }
  .div-line { flex: 1; height: 1px; background: rgba(255,255,255,0.1); }
  .div-txt { font-size: 0.6rem; color: rgba(255,255,255,0.28); letter-spacing: 0.1em; }
  .dr-link { display: block; width: 100%; font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase; background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.28); color: var(--teal); padding: 10px; border-radius: 3px; cursor: pointer; transition: all 0.2s; text-align: center; text-decoration: none; }
  .dr-link:hover { background: rgba(0,212,255,0.18); border-color: var(--teal); }

  .hidden { display: none !important; }

  footer { border-top: 1px solid rgba(255,215,0,0.15); padding: 32px 0; text-align: center; color: rgba(255,255,255,0.25); font-size: 0.7rem; letter-spacing: 0.08em; }
  footer p + p { margin-top: 8px; color: rgba(255,255,255,0.12); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 640px) {
    .form-row { flex-direction: column; }
    .stats-bar { flex-direction: column; }
    .stat-item { border-right: none; border-bottom: 1px solid rgba(255,215,0,0.1); }
    nav { display: none; }
  }

