  function imgHtml(c, isModal) {
    var cls = isModal ? 'modal-hero' : 'card-image';
    var fade = isModal ? 'modal-hero-fade' : 'card-image-fade';
    var inner = c.imageUrl
      ? '<img src="'+esc(c.imageUrl)+'" alt="'+esc(c.imgAlt)+'" loading="lazy">'
      : '<div class="'+(isModal?'modal-hero-placeholder':'card-img-placeholder')+'">'
          + (isModal ? esc(c.icon) : '<span class="ph-icon">'+esc(c.icon)+'</span><span class="ph-label">Image Placeholder</span>')
