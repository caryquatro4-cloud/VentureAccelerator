:root {
  --blue-deep:    #060072;
  --blue:         #0a00a8;
  --blue-nav:     rgba(6,0,114,0.93);
  --yellow:       #FFD700;
  --yellow-dim:   rgba(255,215,0,0.18);
  --teal:         #00d4ff;
  --teal-dim:     rgba(0,212,255,0.12);
  --white:        #f0f0ff;
  --white-dim:    rgba(240,240,255,0.55);
  --grid-line:    rgba(0,212,255,0.045);
  --card-bg:      rgba(255,255,255,0.055);
  --card-border:  rgba(255,215,0,0.2);
}
body {
  font-family:'Exo 2', sans-serif;
  background: var(--blue-deep);
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
}
body::before {
  content:''; position:fixed; inset:0; z-index:0; pointer-events:none;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size:64px 64px;
}
/* ── SITE NAV ── */
.site-nav {
  position:sticky; top:0; z-index:300;
  background:var(--blue-nav); backdrop-filter:blur(18px);
  border-bottom:1px solid rgba(255,215,0,0.18); padding:18px 0;
}
.nav-inner {
  max-width:1280px; margin:0 auto; padding:0 40px;
  display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap;
}
.logo { display:flex; align-items:center; gap:13px; text-decoration:none; flex-shrink:0; }
.logo-hex {
  width:40px; height:40px; flex-shrink:0;
  background:linear-gradient(135deg, var(--yellow) 0%, var(--teal) 100%);
  clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  transition:transform 0.4s ease;
}
.logo:hover .logo-hex { transform:rotate(30deg); }
.logo-wordmark {
  font-family:'Rajdhani',sans-serif; font-weight:700; font-size:1.3rem;
