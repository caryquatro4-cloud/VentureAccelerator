      + inner + '<div class="'+fade+'"></div>' + badge + '</div>';
  }

  function tagsHtml(arr, cls) {
    return arr.map(function(t){ return '<span class="tag '+cls+'">'+esc(t)+'</span>'; }).join('');
  }

  // ── RENDER CARDS ──────────────────────────────────────────────────────────
  function render() {
    var root = document.getElementById('cards-root');
    var html = '';
    SECTIONS.forEach(function(sec) {
      var list = COMPANIES.filter(function(c){
        return c.cat === sec.id && (currentFilter === 'all' || currentFilter === sec.id);
      });
      if (!list.length) return;
      var parts = sec.label.split(' ');
      var titleHtml = '<span>'+esc(parts[0])+'</span> '+parts.slice(1).map(esc).join(' ');
      html += '<div class="section-header"><div class="section-title">'+titleHtml+'</div><div class="section-line"></div></div>';
      html += '<div class="cards-grid">';
      list.forEach(function(c){
        var shortDesc = c.desc.length > 155 ? c.desc.substring(0,155)+'…' : c.desc;
        html +=
          '<div class="card" data-id="'+esc(c.id)+'">'
          + imgHtml(c, false)
          + '<div class="card-header">'
              + '<div><div class="card-company">'+esc(c.name)+'</div>'
              + '<div class="card-sector-tag">'+esc(c.sector)+'</div></div>'
              + '<div class="card-stage">'+esc(c.stage)+'</div>'
          + '</div>'
          + '<div class="card-body">'
