  function setFilter(val) {
    currentFilter = val;
    document.querySelectorAll('[data-filter]').forEach(function(b){
      b.classList.toggle('active', b.getAttribute('data-filter') === val);
    });
    render();
  }

  document.getElementById('nav-bar').addEventListener('click', function(e){
